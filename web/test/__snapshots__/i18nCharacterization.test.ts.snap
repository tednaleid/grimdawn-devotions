  "buildOrder": "<h2>构建顺序</h2><div class="bo-list"><div class="bo-step bo-add" data-con-id="crossroads_order"><span class="bo-n"></span><span class="bo-art"><span class="orb" style="background:#e6c34d"></span></span><span class="bo-name">添加 抉择之地 (NE)</span><span class="bo-pts">+1</span><span class="bo-held">1</span></div><div class="bo-step bo-complete" data-con-id="crane"><span class="bo-n">1</span><span class="bo-name">仙鹤</span><span class="bo-pts">+6</span><span class="bo-held">7</span></div><div class="bo-step bo-refund" data-con-id="crossroads_order"><span class="bo-n"></span><span class="bo-art"><span class="orb" style="background:#e6c34d"></span></span><span class="bo-name">返还 抉择之地 (NE)</span><span class="bo-pts">-1</span><span class="bo-held">6</span></div></div>",
  "buildOrderEmpty": "<h2>构建顺序</h2><div class="bo-empty"><div class="bo-empty-msg">构建未完成: 还需要还需3点天界、还需1点秩序点亲和。</div><div class="bo-empty-sub">添加能提供该亲和的辅助星座。</div></div>",
